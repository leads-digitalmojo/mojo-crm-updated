{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/whatsappWebhook",
        "function": "whatsappWebhook"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8085
    },
    "auth": {
      "port": 9098
    },
    "functions": {
      "port": 5001
    },
    "ui": {
      "enabled": true,
      "port": 4001
    }
  }
}